# ─── Fastest setup: a free cloud model ──────────────────────────────────────
# Just drop in ONE key below and resume-forge auto-detects it — no other config
# needed. Cloud models are seconds per call vs. tens of seconds for a local one.
#
# z.ai / GLM  (recommended free pick — sign in at z.ai, then create a key at
#              https://z.ai/manage-apikey/apikey-list ; glm-4.5-flash is free)
# ZAI_API_KEY=
#
# Google Gemini  (largest free quota — get a key at https://aistudio.google.com/apikey)
# GEMINI_API_KEY=
#
# Groq  (RECOMMENDED: fastest by far — ~8s for a full run incl. cover letter,
#        free, no billing setup. Key: https://console.groq.com/keys)
# GROQ_API_KEY=
#
# Puter  (free GLM with NO z.ai key — free Puter account, then puter.com/dashboard
#         -> API tokens -> Create token ; default model z-ai/glm-4.5-flash)
# PUTER_API_KEY=
#
# Others that also work: OPENROUTER_API_KEY, CEREBRAS_API_KEY.

# ─── Backend / model overrides (optional) ───────────────────────────────────
# Force a backend: zai | glm | gemini | groq | puter | openrouter | cerebras | openai |
#                  ollama | anthropic. Default: a present cloud key, else ollama.
# RESUME_FORGE_LLM_BACKEND=zai
#
# Model id for the chosen backend. Sensible defaults per provider:
#   z.ai -> glm-4.5-flash (or glm-4.7-flash)   gemini -> gemini-2.5-flash
#   groq -> llama-3.3-70b-versatile            ollama -> auto-picks (qwen2.5:3b ...)
# RESUME_FORGE_MODEL=glm-4.5-flash
#
# Generic OpenAI-compatible endpoint (only for backend=openai):
# RESUME_FORGE_OPENAI_BASE_URL=https://your-provider/v1
# RESUME_FORGE_API_KEY=...

# ─── Local Ollama (used when no cloud key is set) ───────────────────────────
# OLLAMA_HOST=http://localhost:11434
# RESUME_FORGE_OLLAMA_NUM_CTX=8192           # raise for very long resume + JD
# RESUME_FORGE_INGEST_MODEL=qwen2.5:7b       # stronger model for empty-parse rescue

# ─── Anthropic (only when RESUME_FORGE_LLM_BACKEND=anthropic) ────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# Cache directory for parsed master profiles (default: ~/.cache/resume_forge)
# RESUME_FORGE_CACHE_DIR=~/.cache/resume_forge
