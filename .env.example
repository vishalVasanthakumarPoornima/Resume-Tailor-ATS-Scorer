# Required: Anthropic API key for JD parsing and resume tailoring
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for parsing/tailoring (default: claude-opus-4-8)
# RESUME_FORGE_MODEL=claude-opus-4-8

# Optional: override the cache directory for parsed master profiles
# RESUME_FORGE_CACHE_DIR=~/.cache/resume_forge
