# LLM backend: "ollama" (default — local, no API key) or "anthropic"
# RESUME_FORGE_LLM_BACKEND=ollama

# Model id for the chosen backend.
# Ollama default: auto-picks an installed model, lightest capable first
# (qwen2.5:3b -> llama3.2:3b -> qwen2.5:7b -> llama3.1 -> ...).
# Anthropic default: claude-opus-4-8
# RESUME_FORGE_MODEL=qwen2.5:3b

# Ollama server location (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Context window requested from Ollama (default: 8192 — keeps memory use low;
# raise it if you have a very long resume + JD and see truncation)
# RESUME_FORGE_OLLAMA_NUM_CTX=8192

# Only needed when RESUME_FORGE_LLM_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Cache directory for parsed master profiles (default: ~/.cache/resume_forge)
# RESUME_FORGE_CACHE_DIR=~/.cache/resume_forge
